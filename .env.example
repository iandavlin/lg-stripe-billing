# App
APP_ENV=dev
APP_DEBUG=true
APP_BASE_URL=https://dev.loothgroup.com/billing
APP_HOME_URL=https://dev.loothgroup.com

# Stripe (test keys for dev)
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Database — reads wp_users during transition, writes its own tables
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lg_membership
DB_USER=lg_membership
DB_PASSWORD=

# WP bridge — reads wp_users for user lookup until migration
WP_DB_NAME=looth_dev
WP_TABLE_PREFIX=wp_

# Mail
MAIL_FROM=no-reply@loothgroup.com
MAIL_FROM_NAME="The Looth Group"
ADMIN_EMAIL=ian.davlin@gmail.com

# JWT — verifies tokens issued by WP companion plugin
JWT_PUBLIC_KEY_PATH=/etc/lg-billing/jwt.pub
